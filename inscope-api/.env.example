# --- Application ---
NODE_ENV=production
PORT=10000

# --- Database (Supabase Pooled / URI，整串) ---
DATABASE_URL=postgresql://postgres.XXXX:ENCODED_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=require
PGSSLMODE=no-verify

# --- CORS (逗号分隔、不要末尾斜杠) ---
CORS_ORIGIN=https://www.inscopei1.com.au, https://andyming13.github.io

# --- JWT ---
JWT_SECRET=replace_with_a_very_long_random_string

# --- Email (本地调试用 log；上线用 resend) ---
EMAIL_MODE=log
RESEND_API_KEY=
EMAIL_FROM="InScope <onboarding@resend.dev>"